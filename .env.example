# AI Service (future)
VITE_AI_SERVICE_URL=http://localhost:3001/api/ai
VITE_AI_ENABLED=false

# IMPORTANT: Do NOT add API keys with the VITE_ prefix — Vite exposes all
# VITE_* variables in the client bundle.  API authentication must be handled
# server-side only (e.g. in the Vite dev-server proxy or a reverse proxy).
# See vite.config.ts proxy section and src/services/AIService.ts for details.
