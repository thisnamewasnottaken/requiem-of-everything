{
  "name": "requiem-of-everything",
  "version": "0.1.0",
  "private": true,
  "description": "An interactive timeline of classical music: composers, compositions, and the world that shaped them.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:changed": "vitest --run --changed --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "i18n:check": "node ./.github/skills/i18n-completeness/scripts/check-and-fill.mjs --check",
    "i18n:strict": "node ./.github/skills/i18n-completeness/scripts/check-and-fill.mjs --check --strict",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "driver.js": "^1.4.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.5",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.13.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  }
}
